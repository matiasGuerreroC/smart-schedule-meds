{
  "expo": {
    "name": "Smart Schedule Meds",
    "slug": "smart-schedule-meds",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.smartschedulemeds"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-font"
    ]
  }
}
